# ─── Google Cloud ───────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Gemini / Vertex AI ─────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
# Set to "mock" to use rule-based fallback instead of Gemini API
GEMINI_MODE=mock

# ─── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-maps-api-key
# Set to "mock" to use estimated distances instead of Maps API
MAPS_MODE=mock

# ─── OpenWeatherMap ──────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-key
# Set to "mock" to use simulated weather risk
WEATHER_MODE=mock

# ─── Disruption Feed (GDACS + ReliefWeb, no key needed) ─────
# Set to "real" for live disaster data, "mock" for offline testing
DISRUPTION_MODE=real

# ─── App Config ──────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
PORT=8000
RISK_ALERT_THRESHOLD=65
